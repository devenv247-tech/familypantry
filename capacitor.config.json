{
  "appId": "ca.nooka.app",
  "appName": "Nooka",
  "webDir": "dist",
  "server": {
    "url": "https://nooka.ca",
    "cleartext": false
  },
  "ios": {
    "contentInset": "always"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2500,
      "launchAutoHide": true,
      "backgroundColor": "#0a1628",
      "showSpinner": false,
      "iosSpinnerStyle": "small",
      "spinnerColor": "#ffffff"
    }
  }
}